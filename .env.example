# Pixie Environment Configuration Template

# Copy this file to .env and fill in your values

## Ollama Configuration
# The URL where Ollama is running (usually local)
OLLAMA_HOST=http://localhost:11434

# The model to use for AI responses
# Options: mistral, neural-chat, dolphin-mixtral, openchat, etc.
OLLAMA_MODEL=mistral

## Backend Configuration
# Host for Python FastAPI server
BACKEND_HOST=127.0.0.1

# Port for Python FastAPI server
BACKEND_PORT=8000

## Database Configuration
# Path to SQLite database file
DATABASE_PATH=./data/pixie.db

## Application Settings
# Maximum tokens to keep in conversation context
MAX_CONTEXT_TOKENS=4096

## Tauri Frontend Configuration
# Development: http://localhost:5173
# Production: Built-in
VITE_API_URL=http://localhost:8000

## Logging
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

## Feature Flags (Phase 2+)
# Enable voice input (requires speech-to-text service)
FEATURE_VOICE=false

# Enable calendar integration
FEATURE_CALENDAR=false

# Enable cloud sync
FEATURE_CLOUD_SYNC=false
